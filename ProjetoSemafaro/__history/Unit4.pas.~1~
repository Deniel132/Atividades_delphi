unit Unit4;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs,Vcl.ExtCtrls, Vcl.StdCtrls,Unit2;

type
  TForm4 = class(TForm)
    amarelo: TShape;
    Button1: TButton;
    Button2: TButton;
    carcaca: TShape;
    Timer1: TTimer;
    verde: TShape;
    vermelho: TShape;
    procedure Back(Sender: TObject);
    procedure Timer1Timer(Sender: TObject);
    procedure iniciarTimer(Sender: TObject);
    procedure FormCreate(Sender: TObject);
  private
    { Private declarations }
  public
    { Public declarations }
  end;

var
  Form4: TForm4;
  estaLigado: boolean;
  corAtiva: integer;

implementation

{$R *.dfm}


procedure TForm4.Back(Sender: TObject);
begin
  Form2.Show;
  Self.Release;
end;


procedure TForm4.FormCreate(Sender: TObject);
begin
  estaLigado  := false;
    corAtiva  := 1;
end;

procedure TForm4.iniciarTimer(Sender: TObject);
begin
    Timer1.Enabled := not estaligado;
    Timer1.Interval := 1000;
end;

procedure TForm4.Timer1Timer(Sender: TObject);
begin
      vermelho.Brush.Color := clblack;
      verde.Brush.Color := clblack;
      amarelo.Brush.Color := clblack;

     if corAtiva = 4 then
      begin
        corAtiva := 1;
      end ;


      case corAtiva of
      1: vermelho.Brush.Color := clred;
      2: verde.Brush.Color := clred;
      3: amarelo.Brush.Color := clred;
      end;

      corAtiva := corAtiva + 1;
end;

end.
