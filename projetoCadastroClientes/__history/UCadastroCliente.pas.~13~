unit UCadastroCliente;

interface

uses
  Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics,
  Vcl.Controls, Vcl.Forms, Vcl.Dialogs, Vcl.StdCtrls, Vcl.ExtCtrls, Vcl.ComCtrls, UDB, UCliente,
  Vcl.Mask, UServiceCliente;

type
  TFrmCadastro = class(TForm)
    Shape1: TShape;
    Label1: TLabel;
    Shape2: TShape;
    Nome: TEdit;
    Shape3: TShape;
    Label2: TLabel;
    Shape4: TShape;
    Label3: TLabel;
    Shape5: TShape;
    Label4: TLabel;
    Shape6: TShape;
    LabelId: TLabel;
    Data: TDateTimePicker;
    ButtonNovoCliente: TButton;
    ButtonCancelar: TButton;
    IdEdit: TEdit;
    MaskEdit1: TMaskEdit;
    procedure ButtonCancelarClick(Sender: TObject);
    procedure ButtonNovoClienteClick(Sender: TObject);
    procedure Editar(id: integer);
    procedure FormCreate(Sender: TObject);
    procedure FormClose(Sender: TObject; var Action: TCloseAction);
    procedure FormKeyDown(Sender: TObject; var Key: Word; Shift: TShiftState);
    procedure NomeKeyPress(Sender: TObject; var Key: Char);
    procedure MaskEdit1KeyPress(Sender: TObject; var Key: Char);
  private
    BackForm: TForm;
    ultimoId: integer;
    EEdicao: boolean;
  public
    { Public declarations }
  end;

var
  FrmCadastro: TFrmCadastro;

implementation

{$R *.dfm}


procedure TFrmCadastro.ButtonNovoClienteClick(Sender: TObject);
var
  Lcliente: Tcliente;
  LClientService: TClientService;
begin
  if trim(Nome.Text) = '' then
  begin
    showmessage('Campo Nome esta Vazio');
    exit;
  end
  else if Length(trim(MaskEdit1.Text)) <> 14 then
  begin
    showmessage('Campo CPF esta Invalido');
    exit;
  end;

  Lcliente := Tcliente.create;
  LClientService := TClientService.create;
  try
    Lcliente.Nome := Nome.Text;
    Lcliente.cpf := MaskEdit1.Text;
    Lcliente.DataNasc := Data.DateTime;

    if EEdicao then
    begin
      Lcliente.codigo := StrToInt(IdEdit.Text);
      LClientService.EditarCliente(Lcliente);
    end
    else
      LClientService.SalvarCliente(Lcliente);

  finally
    LClientService.Free;
    Lcliente.Free;
  end;
  showmessage('Cliente Salvo');
  LClientService.BuscarLista;
  self.close;
end;

procedure TFrmCadastro.Editar(id: integer);
var
  Lcliente: Tcliente;
  LClientService: TClientService;
begin
  LClientService := TClientService.create;
  try
    Lcliente := LClientService.BuscarCliente(id);

    IdEdit.Text := Lcliente.codigo.toString;
    Nome.Text := Lcliente.Nome;
    MaskEdit1.Text := Lcliente.cpf;
    Data.DateTime := Lcliente.DataNasc;

  finally
    LClientService.Free;
    Lcliente.Free;
  end;

  EEdicao := true;
  ButtonNovoCliente.Caption := 'Editar';
  IdEdit.Visible := true;
  LabelId.Visible := true;
end;

procedure TFrmCadastro.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  self.release;
end;

procedure TFrmCadastro.FormCreate(Sender: TObject);
begin
  EEdicao := false;
end;

procedure TFrmCadastro.FormKeyDown(Sender: TObject; var Key: Word;
  Shift: TShiftState);
begin
  if (Key = Ord('S')) and (ssCtrl in Shift) then
    ButtonNovoCliente.Click
  else if (Key = VK_ESCAPE) then
    ButtonCancelar.Click;

  Key := 0;
end;

procedure TFrmCadastro.MaskEdit1KeyPress(Sender: TObject; var Key: Char);
begin
      if Key = #13 then
    Data.SetFocus;
end;

procedure TFrmCadastro.NomeKeyPress(Sender: TObject; var Key: Char);
begin
  if Key = #13 then
    MaskEdit1.SetFocus;
end;

procedure TFrmCadastro.ButtonCancelarClick(Sender: TObject);
begin
  self.close;
end;

end.
